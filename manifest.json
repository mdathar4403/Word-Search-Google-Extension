
{
  "manifest_version": 3,
  "name": "LexiAI",
  "version": "1.0",
  "description": "AI-powered word assistant",
  "icons": {
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://localhost:3000/*"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}